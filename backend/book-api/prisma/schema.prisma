generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  books     Book[]
}

model Book {
  id            Int      @id @default(autoincrement())
  title         String
  author        String
  Isbn          String @unique
  publishedYear Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  userId        Int
  description   String?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
